# ─── MoneyPal Frontend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# On Vercel, set these in: Project Settings → Environment Variables

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Must match the client ID used in the backend.
# From https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── API Backend URL ───────────────────────────────────────────────────────────
# Local dev:
VITE_API_BASE_URL=http://localhost:8000
# Production (replace with your actual Render service URL):
# VITE_API_BASE_URL=https://moneypal-backend.onrender.com
